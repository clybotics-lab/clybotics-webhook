SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Origins allowed to call this API from the browser (do not use * in production).
CORS_ORIGINS=https://app.clybotics.com,http://localhost:8080

# Optional: Meta X-Hub-Signature-256 verification (Facebook + WhatsApp Cloud).
# META_APP_SECRET=

# Optional: require header X-Clybotics-Webhook-Secret on POST bodies (extra gate).
# WEBHOOK_GATE_SECRET=

# Website widget → conversation logs: POST /webhooks/v1/website/message
# JSON: { "bot_id": "<uuid>", "visitor_id": "<stable id>", "message": "...", optional "bot_reply", optional "visitor_name" }
# If your embed already gets the AI reply client-side, send it as bot_reply to avoid a second Dify call on the server.
# When set, require header: X-Clybotics-Website-Secret: <same value> (recommended in production).
# WEBSITE_WIDGET_GATE_SECRET=

# Optional: Dify API root when bot metadata has no difyBaseUrl (before reading runtime_settings.dify_server_base_url from DB).
# DIFY_DEFAULT_BASE_URL=https://api.dify.ai/v1
# DIFY_RUNTIME_BASE_CACHE_SECONDS=300

# --- Lemon Squeezy (card checkout + webhook auto-activation) — set on server for payments ---
# In Lemon: webhook URL POST https://<your-flask-host>/webhooks/v1/lemonsqueezy
# Enable event: subscription_payment_success
# Signing secret: Lemon allows max 40 characters — use e.g. `python -c "import secrets; print(secrets.token_hex(20))"` (exactly 40 hex chars).
LEMONSQUEEZY_API_KEY=your_lemon_api_key
LEMONSQUEEZY_WEBHOOK_SECRET=use_up_to_40_chars_same_as_lemon
LEMONSQUEEZY_STORE_ID=your_lemon_store_id
# Redirect after checkout (your app URL)
LEMONSQUEEZY_CHECKOUT_SUCCESS_URL=https://app.clybotics.com

# Optional variant IDs (defaults in config.py: Starter 1654766, Pro 1654789)
# LEMONSQUEEZY_VARIANT_STARTER=1654766
# LEMONSQUEEZY_VARIANT_PRO=1654789
