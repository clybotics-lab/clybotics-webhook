SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# CORS: comma-separated dashboard origins, or * for development only
# CORS_ORIGINS=https://app.clybotics.com,http://localhost:8080

# Optional: Meta X-Hub-Signature-256 verification (Facebook + WhatsApp Cloud).
# META_APP_SECRET=

# Optional: require header X-Clybotics-Webhook-Secret on POST bodies.
# WEBHOOK_GATE_SECRET=

# DEFAULT_BOT_REPLY=Thanks — we received your message.
